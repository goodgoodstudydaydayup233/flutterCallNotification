<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.callnotification.call_notification">

    <!-- 前台服务 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14+ 前台服务类型：电话 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />
    <!-- 通话管理（phoneCall 类型前台服务所需） -->
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />

    <!-- 唤醒屏幕 -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.DISABLE_KEYGUARD" />

    <!-- 振动 -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- 悬浮窗 / 后台弹出界面 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- 通知权限 (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 精确闹钟权限 (Android 12+): 用于后台定时触发来电通知 -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- 闹钟和提醒权限 (Android 13+ TIRAMISU): 替代 SCHEDULE_EXACT_ALARM -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <application>
        <!-- 来电通知前台服务 -->
        <service
            android:name=".CallNotificationService"
            android:exported="false"
            android:foregroundServiceType="phoneCall" />

        <!-- 全屏来电界面 -->
        <activity
            android:name=".CallActivity"
            android:exported="false"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@android:style/Theme.Translucent.NoTitleBar.Fullscreen" />

        <!-- 来电操作广播接收器 -->
        <receiver
            android:name=".CallActionReceiver"
            android:exported="false" />

        <!-- 定时触发来电通知的 Alarm 广播接收器（绕过 Android 10+ 后台启动限制） -->
        <receiver
            android:name=".CallAlarmReceiver"
            android:exported="false" />
    </application>

</manifest>
